# Build output
build/

# Downloaded Arm GNU Toolchain binaries (managed by tools/scripts/get_toolchain.py)
tools/toolchain/arm-gnu-toolchain-*/
# Keep env.mk (tracks which toolchain source is active)
!tools/toolchain/env.mk

# Downloaded J-Link Software Pack (managed by tools/scripts/get_jlink.py)
tools/jlink/JLink_*/
!tools/jlink/env.mk

# Downloaded xPack OpenOCD binaries (managed by tools/scripts/get_openocd.py)
tools/openocd/xpack-*/
!tools/openocd/env.mk

# Auto-generated OpenOCD target config (tools/scripts/gen_openocd_cfg.py)
.openocd/target.cfg

# SVD peripheral description files (auto-downloaded by gen_openocd_cfg.py)
*.svd

# compile_commands.json copied to root by Makefile for clangd
compile_commands.json

# Temporary files generated by Makefile
**/_summary.py

# Python bytecode cache
tools/scripts/__pycache__/

# Claude Code memory directory
.claude/

# STM32CubeMX generated backup files
*.bak

# Editor / OS
*.DS_Store
Thumbs.db
