{
    "version": "0.2.0",
    "configurations": [
        {
            // ── J-Link ─────────────────────────────────────────────────────
            // device, executable, and svdFile are managed by tools/scripts/gen_openocd_cfg.py.
            // Server path is managed by tools/scripts/get_jlink.py and stored
            // in cortex-debug.JLinkGDBServerPath (settings.json).
            // Run 'make gen-openocd-cfg' (or 'make setup') to populate them.
            "name": "Debug (J-Link)",
            "type": "cortex-debug",
            "request": "launch",
            "servertype": "jlink",
            "device": "STM32XXXXXX",
            "interface": "swd",
            "speed": 4000,
            "executable": "${workspaceFolder}/build/Debug/${workspaceFolderBasename}.elf",
            "runToEntryPoint": "main",
            "preLaunchTask": "build + gen openocd cfg (Debug)",
            // Live Watch: polls selected variables while the MCU is running.
            "liveWatch": { "enabled": true, "samplesPerSecond": 4 },
            // "svdFile": ""   ← populated by gen_openocd_cfg.py
        },
        {
            // ── OpenOCD / DAPLink (CMSIS-DAP) ──────────────────────────────
            // .openocd/target.cfg is generated by gen_openocd_cfg.py and sets
            // the correct WORKAREASIZE for the detected MCU's SRAM size.
            "name": "Debug (OpenOCD / DAPLink)",
            "type": "cortex-debug",
            "request": "launch",
            "servertype": "openocd",
            "configFiles": [
                "interface/cmsis-dap.cfg",
                "${workspaceFolder}/.openocd/target.cfg"
            ],
            "executable": "${workspaceFolder}/build/Debug/${workspaceFolderBasename}.elf",
            "runToEntryPoint": "main",
            "preLaunchTask": "build + gen openocd cfg (Debug)",
            // Live Watch: OpenOCD briefly halts the MCU to read memory, then resumes.
            "liveWatch": { "enabled": true, "samplesPerSecond": 4 },
            // "svdFile": ""   ← populated by gen_openocd_cfg.py
        }
    ]
}
